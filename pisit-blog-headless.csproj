    <PackageReference Include="SkiaSharp" Version="3.119.2" />
    <PackageReference Include="SkiaSharp.NativeAssets.Linux.NoDependencies" Version="3.119.2" />
    <PackageReference Include="YamlDotNet" Version="17.1.0" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="pisit-blog-headless.Tests\**" />
    <EmbeddedResource Remove="pisit-blog-headless.Tests\**" />
    <None Remove="pisit-blog-headless.Tests\**" />
  </ItemGroup>

</Project>
